# Przykładowa konfiguracja środowiska.
# Skopiuj ten plik do ".env" i uzupełnij własnymi wartościami.

# Klucz podpisujący sesje i tokeny CSRF (w produkcji ustaw losowy, długi ciąg).
SECRET_KEY=zmien-mnie-na-losowy-sekret

# Klucz API do modelu Claude (https://console.anthropic.com).
# Bez niego czat AI działa w trybie offline.
ANTHROPIC_API_KEY=

# Opcjonalnie: inny model Claude (domyślnie claude-opus-4-8).
# CLAUDE_MODEL=claude-haiku-4-5
